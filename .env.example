# GhostCrab / MindBrain Studio
# Copy to .env for local development. The npm package also reads these variables.

NODE_ENV=development

# Backend started by Studio when a GhostCrab SQLite database exists.
GHOSTCRAB_BACKEND_ADDR=:8091
# GHOSTCRAB_SQLITE_PATH=~/.ghostcrab/databases/ghostcrab.sqlite

# Existing backend URL. If set, Studio connects to this instead of relying on a
# runtime sidecar written by scripts/backend-sqlite.mjs.
# GHOSTCRAB_MINDBRAIN_URL=http://127.0.0.1:8091
# MINDBRAIN_HTTP_URL=http://127.0.0.1:8091

# GhostCrab install/discovery overrides.
# GHOSTCRAB_BACKEND_BIN=/absolute/path/to/ghostcrab-backend
# GHOSTCRAB_ROOT=/absolute/path/to/ghostcrab-personal-mcp
# GHOSTCRAB_HOME=~/.ghostcrab
# GHOSTCRAB_DATA_DIR=~/.ghostcrab
# GHOSTCRAB_CONFIG_DIR=~/.ghostcrab
# GHOSTCRAB_CONFIG_PATH=
# GHOSTCRAB_ENV_PATH=

# GhostCrab runtime settings accepted for parity with @mindflight/ghostcrab-personal-mcp.
GHOSTCRAB_EMBEDDINGS_MODE=disabled
GHOSTCRAB_EMBEDDING_DIMENSIONS=1536
GHOSTCRAB_EMBEDDINGS_MODEL=openai/text-embedding-3-small
GHOSTCRAB_EMBEDDINGS_API_KEY=
GHOSTCRAB_EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1
GHOSTCRAB_EMBEDDINGS_TIMEOUT_MS=30000
GHOSTCRAB_EMBEDDINGS_FIXTURE_PATH=
GHOSTCRAB_HYBRID_BM25_WEIGHT=0.6
GHOSTCRAB_HYBRID_VECTOR_WEIGHT=0.4
GHOSTCRAB_POSTINSTALL_QUIET=
GHOSTCRAB_SKIP_HOST_BOOTSTRAP=
GHOSTCRAB_SKIP_POSTINSTALL_SMOKE=
GHOSTCRAB_BOOTSTRAP_SEED=1

MB_DOCUMENTS_LLM_MODE=mock
MB_DOCUMENTS_LLM_BASE_URL=https://openrouter.ai/api/v1
MB_DOCUMENTS_LLM_MODEL=qwen/qwen3-coder-next
MB_DOCUMENTS_LLM_API_KEY=
MB_DOCUMENTS_LLM_TIMEOUT_MS=30000

OPENROUTER_API_KEY=

# Offline read-only fixture mode. Studio uses this automatically when no default
# GhostCrab SQLite exists and no explicit --sqlite / GHOSTCRAB_SQLITE_PATH is set.
# DATA_SOURCE=sqlite-demo
# GHOSTCRAB_SQLITE_PATH=fixtures/minimal-graph.sqlite
